# Public app URL, e.g. https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Simple admin gate for creating events
ADMIN_PASSWORD=change-me

# Google OAuth 2.0 credentials (Web application client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/oauth2callback
GOOGLE_REFRESH_TOKEN=

# Optional: Create a dedicated parent folder in Drive and put its ID here.
# If omitted, the app will create event folders directly in your Drive root.
DRIVE_ROOT_FOLDER_ID=
